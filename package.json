{
  "name": "@orchestr-sh/orchestr",
  "type": "module",
  "version": "1.11.1",
  "description": "A 1:1 Laravel replica in TypeScript - Brings Laravel's elegant syntax and architecture to Node.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./Facades": {
      "types": "./dist/Facades/index.d.ts",
      "import": "./dist/Facades/index.mjs",
      "require": "./dist/Facades/index.cjs"
    },
    "./Events": {
      "types": "./dist/Events/index.d.ts",
      "import": "./dist/Events/index.mjs",
      "require": "./dist/Events/index.cjs"
    }
  },
  "bin": {
    "orchestr": "dist/Console/orchestr.mjs"
  },
  "files": [
    "dist",
    "docs",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "type": "build",
              "release": "patch"
            },
            {
              "type": "ci",
              "release": "patch"
            },
            {
              "type": "chore",
              "release": "patch"
            },
            {
              "type": "docs",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "patch"
            },
            {
              "type": "style",
              "release": "patch"
            },
            {
              "type": "test",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(version): release ${nextRelease.version} [skip ci]"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "scripts": {
    "build": "tsdown --format esm --format cjs",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch examples/basic-app/server.ts",
    "prepare": "husky",
    "lint": "oxlint --type-aware --fix src && oxfmt --write src",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "test": "vitest run",
    "test:lint": "oxlint --type-aware src && oxfmt --check src",
    "test:types": "oxlint --type-aware --type-check src",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --type-aware --fix",
      "oxfmt --write"
    ]
  },
  "keywords": [
    "laravel",
    "framework",
    "typescript",
    "nodejs",
    "mvc",
    "ioc",
    "dependency-injection",
    "routing",
    "middleware",
    "service-container",
    "eloquent",
    "backend",
    "web-framework"
  ],
  "author": "Sam Street <samstreet.dev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orchestr-sh/orchestr.git"
  },
  "bugs": {
    "url": "https://github.com/orchestr-sh/orchestr/issues"
  },
  "homepage": "https://github.com/orchestr-sh/orchestr#readme",
  "engines": {
    "node": "^22.14.0 || >= 24.14.0"
  },
  "dependencies": {
    "drizzle-orm": ">=0.30.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0",
    "typescript": ">=5.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.4.0",
    "mysql2": "^3.9.0",
    "postgres": "^3.4.3"
  }
}
